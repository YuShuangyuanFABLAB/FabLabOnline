# 法贝实验室管理系统 环境变量模板
# 复制为 .env 后根据实际环境修改

# 数据库
DB_NAME=fablab
DB_USER=fablab
DB_PASSWORD=<生成强密码: openssl rand -base64 24>
DATABASE_URL=postgresql+asyncpg://fablab:<DB_PASSWORD>@db:5432/fablab

# Redis
REDIS_URL=redis://redis:6379/0

# JWT（生产必须修改！至少 32 字符）
JWT_SECRET_KEY=<生成密钥: openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# 管理员密码（留空则使用默认 admin123，不安全！）
ADMIN_PASSWORD=

# CORS — 允许的域名（逗号分隔）
# HTTP 测试阶段: http://你的IP
# HTTPS 上线后: https://你的域名
CORS_ORIGINS=

# API 文档（生产环境必须 false）
DOCS_ENABLED=true

# 调试模式（HTTP 阶段设 true，HTTPS 上线后改 false）
# true = Cookie 不要求 Secure，适合 HTTP 测试
# false = Cookie 要求 Secure，必须 HTTPS
DEBUG=false

# 微信 OAuth（生产环境配置）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

# 应用
APP_NAME=FabLab Platform
APP_VERSION=1.0.0
TOKEN_EXPIRE_DAYS=7
HEARTBEAT_INTERVAL_SECONDS=300
